{
  "manifest_version": 3,
  "name": "Global Context DB Capture",
  "version": "0.1.0",
  "description": "Save visible web content to the local Global Context DB desktop app.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "action": {
    "default_title": "Save to Global Context DB",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
